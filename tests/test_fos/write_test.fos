name: TE001
date: 03-11-2026
experimenters: [
name: Travis Errthum
affiliation: Kovnir Group - Iowa State University
orcid: 0009-0006-1937-5672
]
internal_project_ID: Ba2-TM5-Pn6
internal_project_description: Unique Clathrate

[Reaction]
// Sometimes you don't want a comment to be read into the synthesis
// because it is meant to be overwritten when saving the synthesis,
// like a calculated value. You can mark these comments with a ! character:
nominal_formula: Ba2Zn5As6
// This is a comment on the nominal_mass
nominal_mass: 250.0
nominal_mass_units: mg

// This is a comment on the Materials block
// This comment is so important it gets two lines
[[Materials]]
:name
:type
:formula
// This is a comment on the supplier key in the Materials block
:supplier
:cas
:form
:purity
:env
:ratio
:treatments

    Barium
    reagent
    Ba
    // This is a comment on the supplier value in the Materials block
    Unk
    1234-56-7
    lump
    0.999
    Ar (g)
    2.0
    [
    type: cutting
    // This is a comment on the repeats value for the treatments of Barium
    repeats: 1
    observations: smaller pieces improve homogenization
    ]

    Zinc
    reagent
    Zn
    Unk
    1234-56-7
    powder
    0.995
    Ar (g)
    5.0
    []

    Antimony
    reagent
    Sb
    Unk
    1234-56-7
    powder
    0.999
    Ar (g)
    6.0
    []

// This is a comment on the treatments block
[[Treatments]]
:type
:repeats
:observations

    weigh
    1
    Weighed stoichiometrically to carbonized ampoule. Barium added last to avoid contact with ampoule during reaction

    seal
    1
    Evacuated ampoule and sealed with H2/O2 torch

    anneal
    1
    Ba lumps reacted but not homogeneous. Small Ba reaction with silica
    program: [[
    type: ramp
    // This is a comment on the ramp temperature for the program of the first annealing under the treatments block.
    temp: 600 C
    time: 10 hr

    // Comments always get linked to the next definition after them. So even though this comment looks like it is for the ramp section of the program,
    // It actually links to the type of the next section of the program
    type: dwell
    time: 120hr
    ]]

    grind
    3
    dark gray powder now

    anneal
    1
    dark gray powder when opening
    program: [[
    :type
    // Nested looped key comment
    :time

        ramp
        10 hr
        temp: 600 C

        dwell
        120hr
    ]]

