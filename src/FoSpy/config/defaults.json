{
    "track_attachments": {
        "new_copy": false,
        "overwrite": false,
        "ignore": false
    },
    "maps": {
        "default": ""
    },
    "DEV": {
        "branch": "main",
        "repo": "../FoSpy"
    },
    "diffraction": {
        "default_engine": "cif2xrd",
        "x_label": "2theta (deg)",
        "engine_parameters": {
